# Farm Credibly — Hermes Agent Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# =============================================================================
# Required
# =============================================================================

# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# LLM Provider — OpenRouter (recommended: supports many models, single API key)
OPENROUTER_API_KEY=

# Telegram user ID of the allowed operator. Message @userinfobot to find yours.
# Used two ways:
#   1. Substituted into config.yaml allowed_users list (YAML env var expansion)
#   2. Read directly by Hermes as TELEGRAM_ALLOWED_USERS for its gateway check
# Both must be set to the same value for reliable allowlisting.
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_ALLOWED_USERS=

# =============================================================================
# Optional — Voice
# =============================================================================

# ElevenLabs (premium TTS — higher quality than Edge TTS)
# If set, change tts.provider to "elevenlabs" in config.yaml
# ELEVENLABS_API_KEY=

# Groq (free STT tier — faster transcription than local faster-whisper)
# If set, change stt.provider to "groq" in config.yaml
# GROQ_API_KEY=

# =============================================================================
# Optional — Model overrides
# =============================================================================

# Override the model for subagent delegation tasks (empty = inherit parent model)
# DELEGATION_MODEL=

# Direct Anthropic API (skip OpenRouter for Anthropic models)
# ANTHROPIC_API_KEY=
